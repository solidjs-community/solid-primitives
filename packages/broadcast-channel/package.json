{
  "name": "@solid-primitives/broadcast-channel",
  "version": "1.0.0-next.1",
  "description": "Primitives to manage Broadcast Channel API",
  "author": "Caleb Taylor <aquaductape@gmail.com>",
  "contributors": [],
  "license": "MIT",
  "homepage": "https://primitives.solidjs.community/package/broadcast-channel",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidjs-community/solid-primitives.git"
  },
  "bugs": {
    "url": "https://github.com/solidjs-community/solid-primitives/issues"
  },
  "primitive": {
    "name": "broadcast-channel",
    "stage": 3,
    "list": [
      "makeBroadcastChannel",
      "createBroadcastChannel"
    ],
    "category": "Browser APIs",
    "gzip": 568
  },
  "keywords": [
    "solid",
    "broadcast-channel",
    "primitives"
  ],
  "private": false,
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./dist/index.js",
  "browser": {},
  "types": "./dist/index.d.ts",
  "exports": {
    "import": {
      "@solid-primitives/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "tsdown": {
    "entry": "src/**/*.{ts,tsx}",
    "outDir": "dist"
  },
  "scripts": {
    "dev": "node --import=@nothing-but/node-resolve-ts --experimental-transform-types ../../scripts/dev.ts",
    "build": "pnpm -w build",
    "vitest": "vitest -c ../../configs/vitest.config.ts",
    "test": "pnpm run vitest",
    "test:ssr": "pnpm run vitest --mode ssr"
  },
  "peerDependencies": {
    "@solidjs/web": "catalog:peer",
    "solid-js": "catalog:peer"
  },
  "typesVersions": {},
  "devDependencies": {
    "@solidjs/web": "catalog:",
    "solid-js": "catalog:"
  }
}
