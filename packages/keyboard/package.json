{
  "name": "@solid-primitives/keyboard",
  "version": "2.0.0-next.4",
  "description": "A library of reactive promitives helping handling user's keyboard input.",
  "author": "Damian Tarnwski <gthetarnav@gmail.com>",
  "contributors": [],
  "license": "MIT",
  "homepage": "https://primitives.solidjs.community/package/keyboard",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidjs-community/solid-primitives.git"
  },
  "bugs": {
    "url": "https://github.com/solidjs-community/solid-primitives/issues"
  },
  "primitive": {
    "name": "keyboard",
    "stage": 3,
    "list": [
      "useKeyDownEvent",
      "useKeyDownList",
      "useCurrentlyHeldKey",
      "useKeyDownSequence",
      "createKeyHold",
      "createShortcut"
    ],
    "category": "Inputs",
    "gzip": 1741
  },
  "keywords": [
    "solid",
    "primitives",
    "keyboard",
    "keystroke",
    "hotkey"
  ],
  "private": false,
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": {},
  "exports": {
    "import": {
      "@solid-primitives/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "tsdown": {
    "entry": "src/**/*.{ts,tsx}",
    "outDir": "dist"
  },
  "scripts": {
    "dev": "node --import=@nothing-but/node-resolve-ts --experimental-transform-types ../../scripts/dev.ts",
    "build": "pnpm -w build",
    "vitest": "vitest -c ../../configs/vitest.config.ts",
    "test": "pnpm run vitest",
    "test:ssr": "pnpm run vitest --mode ssr"
  },
  "dependencies": {
    "@solid-primitives/event-listener": "workspace:^",
    "@solid-primitives/rootless": "workspace:^",
    "@solid-primitives/utils": "workspace:^"
  },
  "peerDependencies": {
    "@solidjs/web": "catalog:peer",
    "solid-js": "catalog:peer"
  },
  "devDependencies": {
    "@solidjs/web": "catalog:",
    "solid-js": "catalog:"
  },
  "typesVersions": {}
}
