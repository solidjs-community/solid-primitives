{
  "name": "@solid-primitives/selection",
  "version": "1.0.0-next.0",
  "description": "selection primitive.",
  "author": "Alex Lohr <alex.lohr@logmein.com>",
  "contributors": [],
  "license": "MIT",
  "homepage": "https://primitives.solidjs.community/package/selection",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidjs-community/solid-primitives.git"
  },
  "bugs": {
    "url": "https://github.com/solidjs-community/solid-primitives/issues"
  },
  "primitive": {
    "name": "selection",
    "stage": 3,
    "list": [
      "createSelection"
    ],
    "category": "Inputs",
    "gzip": 917
  },
  "sideEffects": false,
  "type": "module",
  "module": "./dist/index.js",
  "browser": {},
  "types": "./dist/index.d.ts",
  "exports": {
    "import": {
      "@solid-primitives/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "node --import=@nothing-but/node-resolve-ts --experimental-transform-types ../../scripts/dev.ts",
    "build": "node --import=@nothing-but/node-resolve-ts --experimental-transform-types ../../scripts/build.ts",
    "vitest": "vitest -c vitest.config.ts",
    "test": "pnpm run vitest",
    "test:ssr": "pnpm run vitest --mode ssr"
  },
  "keywords": [
    "solid",
    "primitives"
  ],
  "dependencies": {
    "@solid-primitives/utils": "workspace:^"
  },
  "peerDependencies": {
    "@solidjs/web": "^2.0.0-beta.16",
    "solid-js": "^2.0.0-beta.16"
  },
  "typesVersions": {},
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@solidjs/web": "2.0.0-beta.16",
    "babel-preset-solid": "2.0.0-beta.14",
    "solid-js": "2.0.0-beta.16"
  }
}
