{
  "name": "@solid-primitives/signal-builders",
  "version": "1.0.0-next.2",
  "description": "A collection of chainable and composable reactive signal calculations, aka Signal Builders.",
  "author": "Damian Tarnawski <gthetarnav@gmail.com>",
  "license": "MIT",
  "homepage": "https://primitives.solidjs.community/package/signal-builders",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidjs-community/solid-primitives.git"
  },
  "primitive": {
    "name": "signal-builders",
    "stage": 3,
    "list": [
      "push",
      "filter",
      "sort",
      "map",
      "get",
      "merge",
      "update",
      "add",
      "clamp",
      "template"
    ],
    "category": "Reactivity",
    "gzip": 1514
  },
  "keywords": [
    "solid",
    "primitives",
    "signal",
    "reactive",
    "fp",
    "functional"
  ],
  "files": [
    "dist"
  ],
  "private": false,
  "sideEffects": false,
  "type": "module",
  "module": "./dist/index.js",
  "browser": {},
  "types": "./dist/index.d.ts",
  "exports": {
    "import": {
      "@solid-primitives/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "tsdown": {
    "entry": "src/**/*.{ts,tsx}",
    "outDir": "dist"
  },
  "scripts": {
    "dev": "node --import=@nothing-but/node-resolve-ts --experimental-transform-types ../../scripts/dev.ts",
    "build": "pnpm -w build",
    "vitest": "vitest -c ../../configs/vitest.config.ts",
    "test": "pnpm run vitest",
    "test:ssr": "pnpm run vitest --mode ssr"
  },
  "dependencies": {
    "@solid-primitives/utils": "workspace:^"
  },
  "peerDependencies": {
    "solid-js": "^2.0.0-beta.16"
  },
  "typesVersions": {},
  "devDependencies": {
    "solid-js": "2.0.0-beta.16"
  }
}
