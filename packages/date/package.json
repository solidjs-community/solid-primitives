{
  "name": "@solid-primitives/date",
  "version": "3.0.0-next.2",
  "description": "Collection of reactive primitives and utility functions, providing easier ways to deal with dates in SolidJS",
  "author": "Damian Tarnawski @thetarnav <gthetarnav@gmail.com>",
  "license": "MIT",
  "homepage": "https://primitives.solidjs.community/package/date",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidjs-community/solid-primitives.git"
  },
  "primitive": {
    "name": "date",
    "stage": 3,
    "list": [
      "createDate",
      "createDateNow",
      "createTimeDifference",
      "createTimeDifferenceFromNow",
      "createTimeAgo",
      "createCountdown",
      "createCountdownFromNow"
    ],
    "category": "Utilities",
    "gzip": 1514
  },
  "files": [
    "dist"
  ],
  "private": false,
  "sideEffects": false,
  "type": "module",
  "module": "./dist/index.js",
  "browser": {},
  "types": "./dist/index.d.ts",
  "exports": {
    "import": {
      "@solid-primitives/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "tsdown": {
    "entry": "src/**/*.{ts,tsx}",
    "outDir": "dist"
  },
  "scripts": {
    "start": "vite serve dev",
    "dev": "node --import=@nothing-but/node-resolve-ts --experimental-transform-types ../../scripts/dev.ts",
    "build": "pnpm -w build",
    "vitest": "vitest -c ../../configs/vitest.config.ts",
    "test": "pnpm run vitest",
    "test:ssr": "pnpm run vitest --mode ssr"
  },
  "keywords": [
    "date",
    "time",
    "solid",
    "primitives"
  ],
  "devDependencies": {
    "@solidjs/web": "catalog:",
    "date-fns": "^2.30.0",
    "solid-js": "catalog:"
  },
  "dependencies": {
    "@solid-primitives/timer": "workspace:^",
    "@solid-primitives/utils": "workspace:^"
  },
  "peerDependencies": {
    "@solidjs/web": "catalog:peer",
    "solid-js": "catalog:peer"
  },
  "typesVersions": {}
}
