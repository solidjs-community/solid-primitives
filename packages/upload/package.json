{
  "name": "@solid-primitives/upload",
  "version": "1.0.0-next.2",
  "description": "Primitives for uploading files.",
  "author": "Rustam Ashurmatov <rr.ashurmatov.21@gmail.com>",
  "license": "MIT",
  "homepage": "https://primitives.solidjs.community/package/upload",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidjs-community/solid-primitives.git"
  },
  "primitive": {
    "name": "upload",
    "stage": 3,
    "list": [
      "createFilePicker",
      "createFileUploader",
      "fileSender",
      "fileUploader",
      "createDropzone",
      "dropzone"
    ],
    "category": "Browser APIs",
    "gzip": 2321
  },
  "keywords": [
    "file",
    "file upload",
    "upload",
    "solid",
    "primitives"
  ],
  "files": [
    "dist"
  ],
  "private": false,
  "sideEffects": false,
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": {},
  "exports": {
    "import": {
      "@solid-primitives/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "tsdown": {
    "entry": "src/**/*.{ts,tsx}",
    "outDir": "dist"
  },
  "scripts": {
    "dev": "node --import=@nothing-but/node-resolve-ts --experimental-transform-types ../../scripts/dev.ts",
    "build": "pnpm -w build",
    "vitest": "vitest -c ../../configs/vitest.config.ts",
    "test": "pnpm run vitest",
    "test:ssr": "pnpm run vitest --mode ssr"
  },
  "dependencies": {
    "@solid-primitives/event-listener": "workspace:*"
  },
  "peerDependencies": {
    "@solidjs/web": "catalog:peer",
    "solid-js": "catalog:peer"
  },
  "typesVersions": {},
  "devDependencies": {
    "@solidjs/web": "catalog:",
    "solid-js": "catalog:"
  }
}
