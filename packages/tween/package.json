{
  "name": "@solid-primitives/tween",
  "version": "2.0.0-next.0",
  "description": "Primitive that creates tween functions",
  "author": "Ryan Carniato <ryancarniato@gmail.com>",
  "license": "MIT",
  "homepage": "https://primitives.solidjs.community/package/tween",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidjs-community/solid-primitives.git"
  },
  "primitive": {
    "name": "tween",
    "stage": 3,
    "list": [
      "createTween"
    ],
    "category": "Animation",
    "gzip": 260
  },
  "keywords": [
    "animate",
    "tween",
    "solid",
    "primitives"
  ],
  "files": [
    "dist"
  ],
  "type": "module",
  "private": false,
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": {},
  "exports": {
    "import": {
      "@solid-primitives/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "tsdown": {
    "entry": "src/**/*.{ts,tsx}",
    "outDir": "dist"
  },
  "scripts": {
    "dev": "node --import=@nothing-but/node-resolve-ts --experimental-transform-types ../../scripts/dev.ts",
    "build": "pnpm -w build",
    "vitest": "vitest -c ../../configs/vitest.config.ts",
    "test": "pnpm run vitest",
    "test:ssr": "pnpm run vitest --mode ssr"
  },
  "peerDependencies": {
    "@solidjs/web": "^2.0.0-beta.17",
    "solid-js": "^2.0.0-beta.17"
  },
  "typesVersions": {},
  "devDependencies": {
    "@solidjs/web": "2.0.0-beta.17",
    "solid-js": "2.0.0-beta.17"
  }
}
