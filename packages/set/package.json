{
  "name": "@solid-primitives/set",
  "version": "1.0.0-next.1",
  "description": "Reactive Set and WeakSet primitives with set-algebra operations: union, intersection, difference, and symmetricDifference.",
  "author": "Damian Tarnawski @thetarnav <gthetarnav@gmail.com>",
  "license": "MIT",
  "homepage": "https://primitives.solidjs.community/package/set",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidjs-community/solid-primitives.git"
  },
  "bugs": {
    "url": "https://github.com/solidjs-community/solid-primitives/issues"
  },
  "primitive": {
    "name": "set",
    "stage": 3,
    "list": [
      "ReactiveSet",
      "ReactiveWeakSet",
      "union",
      "intersection",
      "difference",
      "symmetricDifference",
      "readonlySet"
    ],
    "category": "Reactivity",
    "gzip": 793
  },
  "keywords": [
    "solid",
    "primitives",
    "set",
    "reactive",
    "union",
    "intersection",
    "difference"
  ],
  "private": false,
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": {},
  "exports": {
    "import": {
      "@solid-primitives/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "tsdown": {
    "entry": "src/**/*.{ts,tsx}",
    "outDir": "dist"
  },
  "scripts": {
    "dev": "node --import=@nothing-but/node-resolve-ts --experimental-transform-types ../../scripts/dev.ts",
    "build": "pnpm -w build",
    "vitest": "vitest -c ../../configs/vitest.config.ts",
    "test": "pnpm run vitest",
    "test:ssr": "pnpm run vitest --mode ssr"
  },
  "peerDependencies": {
    "@solidjs/web": "catalog:peer",
    "solid-js": "catalog:peer"
  },
  "dependencies": {
    "@solid-primitives/trigger": "workspace:^"
  },
  "typesVersions": {},
  "devDependencies": {
    "@solidjs/web": "catalog:",
    "solid-js": "catalog:"
  }
}
