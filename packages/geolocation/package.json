{
  "name": "@solid-primitives/geolocation",
  "version": "3.0.0-next.0",
  "description": "Primitives to query geolocation and observe changes.",
  "author": "David Di Biase <dave@solidjs.com>",
  "license": "MIT",
  "homepage": "https://primitives.solidjs.community/package/geolocation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidjs-community/solid-primitives.git"
  },
  "primitive": {
    "name": "geolocation",
    "stage": 3,
    "list": [
      "makeGeolocation",
      "makeGeolocationWatcher",
      "createGeolocation",
      "createGeolocationWatcher",
      "createDistance",
      "createWithinRadius"
    ],
    "category": "Browser APIs",
    "gzip": 1225
  },
  "keywords": [
    "geolocation",
    "location",
    "coordinates",
    "primitives"
  ],
  "files": [
    "dist"
  ],
  "private": false,
  "sideEffects": false,
  "type": "module",
  "module": "./dist/index.js",
  "browser": {},
  "types": "./dist/index.d.ts",
  "exports": {
    "import": {
      "@solid-primitives/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "tsdown": {
    "entry": "src/**/*.{ts,tsx}",
    "outDir": "dist"
  },
  "scripts": {
    "dev": "node --import=@nothing-but/node-resolve-ts --experimental-transform-types ../../scripts/dev.ts",
    "build": "pnpm -w build",
    "vitest": "vitest -c ../../configs/vitest.config.ts",
    "test": "pnpm run vitest",
    "test:ssr": "pnpm run vitest --mode ssr"
  },
  "devDependencies": {
    "@solidjs/web": "2.0.0-beta.17",
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "solid-js": "2.0.0-beta.17"
  },
  "dependencies": {
    "@solid-primitives/static-store": "workspace:^",
    "@solid-primitives/utils": "workspace:^"
  },
  "peerDependencies": {
    "@solidjs/web": "2.0.0-beta.17",
    "solid-js": "2.0.0-beta.17"
  },
  "typesVersions": {}
}
