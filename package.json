{
  "name": "solid-primitives",
  "private": true,
  "description": "A collection of high-quality, community contributed building blocks.",
  "homepage": "https://primitives.solidjs.community/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidjs-community/solid-primitives.git"
  },
  "author": "David Di Biase <dave@solidjs.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "generate": "pnpm run build && pnpm -dir site run generate",
    "dev": "pnpm -dir site run dev",
    "format": "prettier --cache -w {site,packages,scripts,template}/**/*.{js,ts,json,css,tsx,jsx,md,html}",
    "lint:packages": "oxlint --max-warnings 0 packages --ignore-pattern \"packages/*/{test,stories,dev}\"",
    "lint:stories": "oxlint packages --ignore-pattern \"packages/*/{src,dev,test}\"",
    "lint:tests": "oxlint packages --ignore-pattern \"packages/*/{src,stories,dev}\"",
    "lint": "pnpm run \"/^lint:.*/\"",
    "test:client": "vitest -c ./configs/vitest.config.ts",
    "test:ssr": "pnpm run test:client --mode ssr",
    "test": "pnpm run test:client && pnpm run test:ssr",
    "test:client2": "vitest -c ./configs/vitest.config.solid2.ts",
    "test:ssr2": "pnpm run test:client2 --mode ssr",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build": "tsdown",
    "new-package": "node --import=@nothing-but/node-resolve-ts --experimental-transform-types ./scripts/new-package.ts",
    "jsr:sync-versions": "node --import=@nothing-but/node-resolve-ts --experimental-transform-types ./scripts/sync-jsr-versions.ts",
    "jsr:sync-versions:check": "node --import=@nothing-but/node-resolve-ts --experimental-transform-types ./scripts/sync-jsr-versions.ts --check",
    "update-readme": "node --import=@nothing-but/node-resolve-ts --experimental-transform-types ./scripts/update-readme.ts",
    "measure": "node --import=@nothing-but/node-resolve-ts --experimental-transform-types ./scripts/measure.ts",
    "version": "changeset version && pnpm i --no-frozen-lockfile && git add .",
    "release": "pnpm build && changeset publish",
    "release-tagged": "pnpm build && (test -f .changeset/pre.json && changeset publish || changeset publish --tag $BRANCH_NAME)"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@changesets/cli": "^2.31.0",
    "@nothing-but/node-resolve-ts": "^1.0.1",
    "@solid-primitives/a11y": "workspace:*",
    "@solidjs/signals": "2.0.0-beta.14",
    "@solidjs/web": "2.0.0-beta.16",
    "@storybook/addon-docs": "^10.4.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.20.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "babel-preset-solid": "2.0.0-beta.14",
    "esbuild": "^0.28.1",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "geist": "^1.7.2",
    "jsdom": "^25.0.1",
    "json-to-markdown-table": "^1.0.0",
    "oxlint": "^1.72.0",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "solid-js": "2.0.0-beta.16",
    "storybook": "^10.4.6",
    "storybook-solidjs-vite": "^10.5.2",
    "tsdown": "catalog:",
    "typescript": "^7.0.2",
    "unplugin-solid": "catalog:",
    "vite": "^6.4.3",
    "vite-plugin-solid": "3.0.0-next.5",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "engines": {
    "node": ">=22.0.0"
  }
}
